# ─── Server ──────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
APP_URL=http://localhost:4000
WEB_URL=http://localhost:5173

# ─── Database (PostgreSQL) ───────────────────────────────────────────────────
# Example local DSN:
#   postgresql://postgres:postgres@127.0.0.1:5432/skillforge
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/skillforge
POSTGRES_DB=skillforge
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string-of-at-least-32-chars
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# ─── Auth providers ──────────────────────────────────────────────────────────
# Comma-separated list of providers this deployment supports. Drop entries
# you don't want to expose (e.g. AUTH_PROVIDERS=local for an air-gapped
# install with no internet OAuth). See docs/decisions/0005-pluggable-auth-providers.md.
AUTH_PROVIDERS=local,google,microsoft

# ─── Google OAuth ────────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Add an "OAuth 2.0 Client ID" of type "Web application"
# Authorised JavaScript origins:  http://localhost:5173
# Authorised redirect URIs:       http://localhost:4000/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback
GOOGLE_FRONTEND_REDIRECT=http://localhost:5173/auth/callback

# ─── Microsoft 365 / Azure AD SSO ───────────────────────────────────────
# Create an App Registration at https://portal.azure.com → Azure Active Directory
# → App registrations → New registration.
# Redirect URI: http://localhost:4000/api/auth/oauth/microsoft/callback (Web platform)
# MICROSOFT_TENANT_ID: your Azure AD tenant GUID for single-tenant mode,
# or 'common' for multi-tenant (any Microsoft account). Defaults to 'common'.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:4000/api/auth/oauth/microsoft/callback
MICROSOFT_FRONTEND_REDIRECT=http://localhost:5173/auth/callback

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173,http://localhost:3000,http://localhost:5174

# ─── Logging ─────────────────────────────────────────────────────────────────
# Pino log level: trace | debug | info | warn | error | fatal | silent.
# Defaults: development=debug, test=warn, production=info.
LOG_LEVEL=

# ─── Error tracking (optional) ───────────────────────────────────────────────
# Sentry / Glitchtip DSN. Leave blank to disable error tracking entirely.
# Glitchtip is the open-source self-hostable option recommended for on-prem.
SENTRY_DSN=
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0

# ─── Judge queue (per ADR 0013) ──────────────────────────────────────────────
# Submit pipeline mode:
#   inline — runs the judge in-process (default for dev/test, no Redis needed)
#   bullmq — enqueues onto Redis-backed BullMQ; consumed by `npm run worker`
#            in a separate process
JUDGE_QUEUE=inline
REDIS_URL=redis://127.0.0.1:6379
REDIS_PORT=6379

# ─── External language runtimes (Python / Java / Go / C++) ──────────────────
# Controls how the polyglot function judge and the STDIO judge execute
# submissions in languages other than JavaScript.
#
# auto   — use local runtimes first, then already-pulled Docker images
# local  — use only local `python3`/`javac`/`go`/`g++` binaries
# docker — use Docker sandbox containers (requires Docker CLI + images)
# off    — disable external language runtimes (STDIO judge returns JUDGE_ERROR)
JUDGE_RUNTIME_MODE=auto
JUDGE_NODE_IMAGE=node:20-alpine
JUDGE_PYTHON_IMAGE=python:3.12-alpine
JUDGE_JAVA_IMAGE=eclipse-temurin:21-jdk-alpine
JUDGE_GO_IMAGE=golang:1.23-alpine
JUDGE_CPP_IMAGE=gcc:13-bookworm

# ─── Docker isolation (per-submission container hardening) ───────────────────
# These control the hardened container flags applied to every submission
# when JUDGE_RUNTIME_MODE=docker. All have sensible defaults.
# JUDGE_DOCKER_PIDS_LIMIT=64          # Max processes inside container (prevents fork bombs)
# JUDGE_DOCKER_CPU_LIMIT=1            # CPU cores allocated to container
# JUDGE_DOCKER_NOFILE_LIMIT=64        # Max open file descriptors
# JUDGE_DOCKER_TMPFS_SIZE_MB=128      # Writable tmpfs size in MB
# JUDGE_DOCKER_COMPILE_OVERHEAD_MS=30000  # Compile time budget added to per-submission timeout
# JUDGE_SECCOMP_PROFILE=              # Path to custom seccomp JSON profile (optional)

# Number of concurrent judge jobs a single worker process pulls in parallel.
# Each in-flight JS judge holds ~32 MB in its V8 isolate, so the upper bound
# is governed by the worker container memory budget.
JUDGE_WORKER_CONCURRENCY=2

# ─── Contest mode (per ADR 0017) ─────────────────────────────────────────────
# Contest mode adds no new environment variables. Contest submissions reuse
# the existing async judge pipeline (ADR 0013), so operators can scale
# contest judging under load by switching JUDGE_QUEUE=bullmq and pointing
# REDIS_URL at a Redis instance — the same knobs that scale regular
# submission judging. JUDGE_WORKER_CONCURRENCY and the JUDGE_RUNTIME_MODE
# family apply to contest submissions unchanged.
