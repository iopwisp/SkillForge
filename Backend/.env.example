# ─── Server ──────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
APP_URL=http://localhost:4000
WEB_URL=http://localhost:5173

# ─── Database (SQLite, file path) ────────────────────────────────────────────
DATABASE_FILE=./data/skillforge.db

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string-of-at-least-32-chars
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# ─── Google OAuth ────────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Add an "OAuth 2.0 Client ID" of type "Web application"
# Authorised JavaScript origins:  http://localhost:5173
# Authorised redirect URIs:       http://localhost:4000/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback
GOOGLE_FRONTEND_REDIRECT=http://localhost:5173/auth/callback

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173,http://localhost:3000,http://localhost:5174
