# Docker Compose overrides for the legacy Java microservices scaffold.
# Copy to `.env` only if you intentionally run `docker compose up` from Backend/.

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=taskhub
POSTGRES_MULTIPLE_DATABASES=auth_service_db,user_service_db,task_service_db,submission_service_db,rating_service_db,notification_service_db

# Shared service settings
SPRING_PROFILES_ACTIVE=prod
JWT_SECRET=change-me-to-a-long-random-string-of-at-least-32-chars
EUREKA_URL=http://discovery-service:8761/eureka/
REDIS_HOST=redis
REDIS_PORT=6379
KAFKA_SERVERS=kafka:9092
KAFKA_HOST_PORT=19092

# Notification service
MAIL_USERNAME=placeholder@example.com
MAIL_PASSWORD=change-me
